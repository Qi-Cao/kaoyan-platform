npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
.pnp.*

# 本地环境文件
frontend/.env
frontend/.env.local
frontend/.env.*.local

# 测试覆盖率报告
frontend/coverage/

